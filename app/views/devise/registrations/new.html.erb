<h2 class="text-center text-2xl font-bold mb-4">Sign up</h2>

<div class="container mt-4 rounded border border-secondary p-4">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" class="form-control" name="user[email]" id="user_email" required autofocus autocomplete="email">
    </div>

    <div class="mb-3">
      <label class="form-label">Password</label>
      <%= f.password_field :password, class: "form-control rounded-0", autocomplete: "new-password" %>
      <small class="form-text text-muted">
        <%= @minimum_password_length %> characters minimum
      </small>
    </div>

    <div class="mb-3">
      <label class="form-label">Password confirmation</label>
      <%= f.password_field :password_confirmation, class: "form-control rounded-0", autocomplete: "new-password" %>
    </div>

    <button type="submit" class="btn btn-primary rounded-0">Sign up</button>
  <% end %>
</div>

<%= render "devise/shared/links" %>
