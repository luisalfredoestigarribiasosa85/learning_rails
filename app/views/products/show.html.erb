<div class="container">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-white border rounded-3 p-3 mb-0">
          <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
          <li class="breadcrumb-item active" aria-current="page"><%= @product.name %></li>
        </ol>
      </nav>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 p-md-5">
          <h1 class="card-title h2 fw-bold mb-2"><%= @product.name %></h1>
          <p class="text-secondary mb-4">Product ID: <code><%= @product.id %></code></p>

          <div class="mb-4">
            <h2 class="h6 fw-semibold text-secondary text-uppercase mb-3">Details</h2>
            <div class="row g-3">
              <div class="col-md-6">
                <p class="mb-1 text-secondary">Created</p>
                <p class="fw-semibold mb-0"><%= @product.created_at.strftime("%B %d, %Y") %></p>
              </div>
              <div class="col-md-6">
                <p class="mb-1 text-secondary">Last updated</p>
                <p class="fw-semibold mb-0"><%= @product.updated_at.strftime("%B %d, %Y") %></p>
              </div>
            </div>
          </div>

          <div class="d-grid d-sm-flex gap-2 flex-wrap">
            <% if current_user.admin? %>
              <%= link_to "Edit", edit_product_path(@product), class: "btn btn-primary" %>
              <%= button_to "Delete", product_path(@product), method: :delete, data: { turbo_confirm: "Delete this product permanently?" }, class: "btn btn-outline-danger" %>
            <% end %>
            <%= link_to "Back to products", products_path, class: "btn btn-outline-secondary" %>
          </div>
        </div>
      </div>

      <div class="alert alert-light border" role="note">
        <h2 class="h6 alert-heading mb-2">Tip</h2>
        <p class="mb-0 text-secondary">Keep product names consistent so they are easier to find and manage later.</p>
      </div>
    </div>
  </div>
</div>
