<div class="container">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-white border rounded-3 p-3 mb-0">
          <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
          <li class="breadcrumb-item active" aria-current="page"><%= @product.name %></li>
        </ol>
      </nav>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 p-md-5">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <h1 class="card-title h2 fw-bold mb-0"><%= @product.name %></h1>
            <span class="h3 fw-bold text-primary"><%= @product.formatted_price %></span>
          </div>

          <div class="d-flex gap-2 mb-4">
            <% if @product.active? %>
              <span class="badge bg-success">Active</span>
            <% else %>
              <span class="badge bg-secondary">Inactive</span>
            <% end %>
            <% if @product.stock_status == "out_of_stock" %>
              <span class="badge bg-danger">Out of stock</span>
            <% elsif @product.stock_status == "low_stock" %>
              <span class="badge bg-warning text-dark">Low stock: <%= @product.stock %></span>
            <% else %>
              <span class="badge bg-success">In stock: <%= @product.stock %></span>
            <% end %>
          </div>

          <% if @product.description.present? %>
            <div class="mb-4">
              <h2 class="h6 fw-semibold text-secondary text-uppercase mb-2">Description</h2>
              <p class="mb-0"><%= @product.description %></p>
            </div>
          <% end %>

          <div class="mb-4">
            <h2 class="h6 fw-semibold text-secondary text-uppercase mb-3">Details</h2>
            <div class="row g-3">
              <div class="col-md-6">
                <p class="mb-1 text-secondary">Stock</p>
                <p class="fw-semibold mb-0"><%= @product.stock %> units</p>
              </div>
              <div class="col-md-6">
                <p class="mb-1 text-secondary">Status</p>
                <p class="fw-semibold mb-0"><%= @product.active? ? "Active" : "Inactive" %></p>
              </div>
              <div class="col-md-6">
                <p class="mb-1 text-secondary">Created</p>
                <p class="fw-semibold mb-0"><%= @product.created_at.strftime("%B %d, %Y") %></p>
              </div>
              <div class="col-md-6">
                <p class="mb-1 text-secondary">Last updated</p>
                <p class="fw-semibold mb-0"><%= @product.updated_at.strftime("%B %d, %Y") %></p>
              </div>
            </div>
          </div>

          <div class="d-grid d-sm-flex gap-2 flex-wrap">
            <% if current_user.admin? %>
              <%= link_to "Edit", edit_product_path(@product), class: "btn btn-primary" %>
              <%= button_to "Delete", product_path(@product), method: :delete, data: { turbo_confirm: "Delete this product permanently?" }, class: "btn btn-outline-danger" %>
            <% end %>
            <%= link_to "Back to products", products_path, class: "btn btn-outline-secondary" %>
          </div>
        </div>
      </div>

      <div class="alert alert-light border" role="note">
        <h2 class="h6 alert-heading mb-2">Tip</h2>
        <p class="mb-0 text-secondary">Keep product names consistent so they are easier to find and manage later.</p>
      </div>
    </div>
  </div>
</div>
