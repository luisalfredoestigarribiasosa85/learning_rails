<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <!-- Breadcrumb Navigation -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-light p-3 rounded">
          <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
          <li class="breadcrumb-item active" aria-current="page"><%= @product.name %></li>
        </ol>
      </nav>

      <!-- Product Card -->
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-5">
          <h1 class="card-title display-5 fw-bold mb-2"><%= @product.name %></h1>
          <p class="text-muted mb-4">Product ID: <code><%= @product.id %></code></p>
          
          <hr class="my-4">
          
          <!-- Product Details Section -->
          <div class="mb-5">
            <h5 class="fw-semibold text-secondary mb-3">Product Details</h5>
            <div class="row">
              <div class="col-md-6">
                <p class="mb-2"><span class="text-muted">Created:</span></p>
                <p class="fw-semibold"><%= @product.created_at.strftime("%B %d, %Y") %></p>
              </div>
              <div class="col-md-6">
                <p class="mb-2"><span class="text-muted">Last Updated:</span></p>
                <p class="fw-semibold"><%= @product.updated_at.strftime("%B %d, %Y") %></p>
              </div>
            </div>
          </div>

          <hr class="my-4">

          <!-- Actions -->
          <div class="d-flex gap-2 flex-wrap">
            <%= link_to '✏️ Edit', edit_product_path(@product), class: 'btn btn-primary btn-lg' %>
            <%= button_to '🗑️ Delete', product_path(@product), method: :delete, data: { turbo_confirm: 'Are you sure? This action cannot be undone.' }, class: 'btn btn-danger btn-lg' %>
            <%= link_to '← Back to Products', products_path, class: 'btn btn-outline-secondary btn-lg' %>
          </div>
        </div>
      </div>

      <!-- Info Alert -->
      <div class="alert alert-info border-0" role="alert">
        <h6 class="alert-heading">💡 Tip</h6>
        <p class="mb-0">You can edit this product's information or delete it permanently using the buttons above.</p>
      </div>
    </div>
  </div>
</div>
