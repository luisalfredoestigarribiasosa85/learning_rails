<h1>Products</h1>

<p>
  <%= link_to "New Product", new_product_path, class: "btn btn-primary" %>
</p>

<% if @products.any? %>
  <table class="table table-striped">
    <thead class="thead-dark">
      <tr class="table-primary">
        <th class="col-md-8">Name</th>
        <th colspan="3"></th>
      </tr>
    </thead>

    <tbody class="table-light">
      <% @products.each do |product| %>
        <tr class="table-secondary">
          <td class="col-md-8"><%= product.name %></td>
          <td class="col-md-2"><%= link_to "Show", product_path(product), class: "btn btn-info" %></td>
          <td class="col-md-2"><%= link_to "Edit", edit_product_path(product), class: "btn btn-warning" %></td>
          <td class="col-md-2"><%= link_to "Destroy", product_path(product), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No products yet.</p>
<% end %>
