<div class="container">
  <div class="row g-3 align-items-end mb-4">
    <div class="col-md-8">
      <h1 class="display-6 fw-bold mb-2">Products</h1>
      <p class="text-secondary mb-0">Manage your catalog in one place.</p>
    </div>
    <% if current_user.admin? %>
      <div class="col-md-4 d-grid d-md-flex justify-content-md-end">
        <%= link_to "New product", new_product_path, class: "btn btn-primary btn-lg px-4" %>
      </div>
    <% end %>
  </div>

  <% if @products.any? %>
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
          <tr>
            <th class="fw-semibold">Name</th>
            <th class="fw-semibold text-end">Price</th>
            <th class="fw-semibold text-center">Stock</th>
            <th class="fw-semibold text-center">Status</th>
            <th class="text-end fw-semibold">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <tr class="<%= 'text-muted opacity-50' unless product.active? %>">
              <td class="py-3">
                <h5 class="mb-0 fw-semibold"><%= product.name %></h5>
                <% if product.description.present? %>
                  <small class="text-secondary d-block text-truncate" style="max-width: 300px;"><%= product.description %></small>
                <% end %>
              </td>
              <td class="py-3 text-end">
                <span class="fw-bold text-primary"><%= product.formatted_price %></span>
              </td>
              <td class="py-3 text-center">
                <% if product.stock_status == "out_of_stock" %>
                  <span class="badge bg-danger">Out of stock</span>
                <% elsif product.stock_status == "low_stock" %>
                  <span class="badge bg-warning text-dark"><%= product.stock %> Low</span>
                <% else %>
                  <span class="badge bg-success"><%= product.stock %> In stock</span>
                <% end %>
              </td>
              <td class="py-3 text-center">
                <% if product.active? %>
                  <span class="badge bg-success">Active</span>
                <% else %>
                  <span class="badge bg-secondary">Inactive</span>
                <% end %>
              </td>
              <td class="py-3 text-end">
                <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                  <%= link_to "View", product_path(product), class: "btn btn-sm btn-outline-primary" %>
                  <% if current_user.admin? %>
                    <%= link_to "Edit", edit_product_path(product), class: "btn btn-sm btn-outline-secondary" %>
                    <%= button_to "Delete", product_path(product), method: :delete, data: { turbo_confirm: "Delete this product permanently?" }, class: "btn btn-sm btn-outline-danger" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    </div>
  <% else %>
    <div class="alert alert-light border text-center py-5" role="status">
      <h5 class="fw-semibold">No products yet</h5>
      <p class="mb-3 text-secondary">Create your first product to get started.</p>
      <% if current_user.admin? %>
        <%= link_to "Create Product", new_product_path, class: "btn btn-primary" %>
      <% end %>
    </div>
  <% end %>
</div>
